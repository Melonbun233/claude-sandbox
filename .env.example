# ── Mode ──────────────────────────────────────────────────────────────────────
# develop | pr-review
MODE=develop

# ── Anthropic / LLM Proxy ────────────────────────────────────────────────────
# HAI proxy or custom API endpoint (e.g., http://host.docker.internal:8080/v1)
ANTHROPIC_BASE_URL=
# Bearer token for the proxy
ANTHROPIC_AUTH_TOKEN=
# Direct API key (alternative to proxy)
# ANTHROPIC_API_KEY=

# ── GitHub ────────────────────────────────────────────────────────────────────
# Tokens for each GitHub server (referenced by token_env in workspace.yaml)
# github.com token
GH_TOKEN=
# Enterprise server tokens (add as many as needed, name them in workspace.yaml)
GH_ENTERPRISE_TOKEN=
# Git identity
GIT_USER_NAME=
GIT_USER_EMAIL=

# ── Jira (read-only queries) ─────────────────────────────────────────────────
# Jira instance URL (e.g., https://mycompany.atlassian.net)
JIRA_URL=
# Jira Cloud: your email; Jira DC: your username
JIRA_USERNAME=
# Jira Cloud: API token; Jira DC: personal access token
JIRA_API_TOKEN=
# cloud | datacenter (default: cloud)
JIRA_AUTH_TYPE=cloud

# ── PR Review mode options ────────────────────────────────────────────────────
# PR number (e.g., 123 or org/repo#123)
PR_NUMBER=
# Repository (e.g., org/repo) — optional if running inside the cloned repo
PR_REPO=
# Dry-run outputs review to file instead of posting (default: true)
DRY_RUN=true

# ── Develop mode options ──────────────────────────────────────────────────────
# Set to true to use --dangerously-skip-permissions in develop mode
SKIP_PERMISSIONS=false
