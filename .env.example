# ── Anthropic / LLM Proxy (optional overrides) ─────────────────────────────
# By default, config is inherited from the host's ~/.claude.json and
# ~/.claude/settings.json. Only set these to override the host config.
# ANTHROPIC_BASE_URL=
# ANTHROPIC_AUTH_TOKEN=
# ANTHROPIC_API_KEY=

# ── GitHub ────────────────────────────────────────────────────────────────────
# Tokens for each GitHub server. Variable names must match token_env in
# workspace.yaml — use any name you want (e.g., GH_MY_SERVER_TOKEN).
# Tokens are required for servers with auth_method: https.
# For servers with auth_method: ssh, tokens are optional (enables gh CLI only).
GH_TOKEN=
# GH_ENTERPRISE_TOKEN=

# ── Jira (read-only queries) ─────────────────────────────────────────────────
# Jira instance URL (e.g., https://mycompany.atlassian.net)
JIRA_URL=
# Jira Cloud: your email; Jira DC: your username
JIRA_USERNAME=
# Jira Cloud: API token; Jira DC: personal access token
JIRA_API_TOKEN=
# cloud | datacenter (default: cloud)
JIRA_AUTH_TYPE=cloud
