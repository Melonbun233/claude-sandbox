#!/usr/bin/env bash
set -euo pipefail

# ── claude-sandbox — CLI wrapper for claude-sandbox ──────────────────────────────

COMPOSE="docker compose"
# Resolve symlinks to find the real script location (supports `install` symlink)
_source="${BASH_SOURCE[0]}"
while [ -L "$_source" ]; do
  _dir="$(cd "$(dirname "$_source")" && pwd)"
  _source="$(readlink "$_source")"
  # If readlink returns a relative path, resolve it relative to the symlink dir
  [[ "$_source" != /* ]] && _source="$_dir/$_source"
done
SCRIPT_DIR="$(cd "$(dirname "$_source")" && pwd)"
unset _source _dir
ORIGINAL_CWD="$(pwd)"

cd "$SCRIPT_DIR"

usage() {
  cat <<'EOF'
Usage: claude-sandbox <command> <session-name> [options]

A session name is required for all commands (except build, list, help).

Commands:
  build                                Build the container image
  install [--prefix=<path>]               Install CLI globally (symlink)
  launch <name> [--repo=<path>]... [--copy=<src>]... [opts]  Start + attach in one step
  start <name> [--repo=<path>]... [--copy=<src>]... [opts]  Start a new session
  attach <name> [--dangerously-skip-permissions]            Attach to a running session
  run <name> --prompt=<text> [--repo=<path>]... [--copy=<src>]...  Run a one-shot prompt
  status <name>                        Show session status
  logs <name>                          Tail session output log
  stop <name>                          Stop session (can be restarted later)
  delete <name>                        Permanently remove session and its data
  list                                 List all sessions
  enable-qemu                          Register QEMU binfmt handlers for multi-arch builds
  help [command]                       Show help for a command

Run 'claude-sandbox help <command>' for detailed help on a specific command.
EOF
}

command_help() {
  case "${1:-}" in
    build)
      cat <<'EOF'
Usage: claude-sandbox build

Build (or rebuild) the container image. Run this after pulling updates
or modifying the Dockerfile.

Examples:
  claude-sandbox build
EOF
      ;;
    install)
      cat <<'EOF'
Usage: claude-sandbox install [--prefix=/usr/local/bin]

Create a symlink so you can run 'claude-sandbox' from any directory.
Default prefix is /usr/local/bin.

Examples:
  claude-sandbox install
  claude-sandbox install --prefix=$HOME/.local/bin
EOF
      ;;
    launch)
      cat <<'EOF'
Usage: claude-sandbox launch <session-name> [options]

Start a session and immediately attach to Claude Code. If the session
is already running, you'll be prompted to re-attach or replace it.

Options:
  --dangerously-skip-permissions    Run Claude without tool confirmation prompts
  --rm                  Auto-remove session when Claude exits
  --repo=<path>[:<name>]  Source repo to copy into sandbox (repeatable)
                        Defaults to current working directory if not specified
  --copy=<src>[:<dest>][:<mode>]  Copy file/dir into container (repeatable)
                        dest defaults to same path, mode defaults to ro

Examples:
  claude-sandbox launch my-feature
  claude-sandbox launch my-feature --repo=~/repos/api
  claude-sandbox launch my-feature --repo=~/repos/api --repo=~/repos/config
  claude-sandbox launch my-feature --copy=~/.aws --copy=~/.kube/config
  claude-sandbox launch my-feature --repo=~/repos/api:backend --copy=./env:/workspace/backend/.env:rw
  claude-sandbox launch my-feature --rm
EOF
      ;;
    start)
      cat <<'EOF'
Usage: claude-sandbox start <session-name> [options]

Start a new session or restart a stopped one. Each session gets its own
container and persistent workspace volume.

Options:
  --dangerously-skip-permissions    Run Claude without tool confirmation prompts
  --repo=<path>[:<name>]  Source repo to copy into sandbox (repeatable)
                        Defaults to current working directory if not specified
  --copy=<src>[:<dest>][:<mode>]  Copy file/dir into container (repeatable)
                        dest defaults to same path, mode defaults to ro

If the session was previously stopped, it is restarted with its existing
workspace data intact.

Examples:
  claude-sandbox start my-feature
  claude-sandbox start my-feature --repo=~/repos/api
  claude-sandbox start my-feature --repo=~/repos/api --repo=~/repos/config
  claude-sandbox start my-feature --copy=~/.aws --copy=~/.kube/config::rw
EOF
      ;;
    attach)
      cat <<'EOF'
Usage: claude-sandbox attach <session-name> [options]

Attach to a running session interactively with Claude Code.

Options:
  --dangerously-skip-permissions    Run Claude without tool confirmation prompts

The session must be running. If stopped, use 'start' to restart it first.

Examples:
  claude-sandbox attach my-feature
  claude-sandbox attach my-feature --dangerously-skip-permissions
EOF
      ;;
    run)
      cat <<'EOF'
Usage: claude-sandbox run <session-name> --prompt=<text> [options]
       claude-sandbox run <session-name> --pr=<ref> [options]

Run a one-shot prompt in a fresh container. The session is auto-removed
after completion unless --keep is specified.

Options:
  --prompt=<text>       Prompt to send to Claude (required unless --pr)
  --pr=<ref>            PR review shorthand: number or org/repo#number
  --post                Post PR review to GitHub after completion
  --keep                Preserve session for later inspection (default: auto-remove)
  --repo=<path>[:<name>]  Source repo to copy into sandbox (repeatable)
                        Defaults to current working directory if not specified
  --copy=<src>[:<dest>][:<mode>]  Copy file/dir into container (repeatable)
                        dest defaults to same path, mode defaults to ro

Examples:
  claude-sandbox run task1 --prompt "Respond with only: test successful"
  claude-sandbox run task1 --prompt "Run tests" --repo=~/repos/api
  claude-sandbox run task1 --prompt "Run tests" --repo=~/repos/api --copy=~/.aws
  claude-sandbox run review1 --pr=123
  claude-sandbox run review2 --pr=org/repo#456 --post
EOF
      ;;
    status)
      cat <<'EOF'
Usage: claude-sandbox status <session-name>

Show session status including type, start time, and container info.
For stopped sessions, shows restart/delete instructions.

Examples:
  claude-sandbox status my-feature
EOF
      ;;
    logs)
      cat <<'EOF'
Usage: claude-sandbox logs <session-name>

Tail the session output log. The session must be running.

Examples:
  claude-sandbox logs my-feature
EOF
      ;;
    stop)
      cat <<'EOF'
Usage: claude-sandbox stop <session-name>

Stop a running session. The container and workspace volume are preserved,
so you can restart it later with 'start'.

Examples:
  claude-sandbox stop my-feature
  claude-sandbox start my-feature    # restart later
EOF
      ;;
    delete)
      cat <<'EOF'
Usage: claude-sandbox delete <session-name>

Permanently remove a session's container and workspace volume. This
cannot be undone — all workspace files and session data are lost.

Examples:
  claude-sandbox delete my-feature
EOF
      ;;
    list)
      cat <<'EOF'
Usage: claude-sandbox list

List all sessions (running and stopped) with their status.

Examples:
  claude-sandbox list
EOF
      ;;
    enable-qemu)
      cat <<'EOF'
Usage: claude-sandbox enable-qemu

Register QEMU binfmt handlers on the host for multi-architecture
container image builds. This is a one-time host-level setup.

Runs: docker run --privileged --rm tonistiigi/binfmt --install all

This also clears the 'don't ask again' suppression if previously set.

Examples:
  claude-sandbox enable-qemu
EOF
      ;;
    help)
      cat <<'EOF'
Usage: claude-sandbox help [command]

Show general help, or detailed help for a specific command.

Examples:
  claude-sandbox help
  claude-sandbox help start
  claude-sandbox help attach
EOF
      ;;
    "")
      usage
      ;;
    *)
      echo "Unknown command: $1"
      echo ""
      usage
      exit 1
      ;;
  esac
}

# ── Parse command ────────────────────────────────────────────────────────────
COMMAND="${1:-}"
shift || true

# Commands that don't need a session name
case "$COMMAND" in
  build|list|install|enable-qemu|"")
    # handled below without session name
    ;;
  help|--help|-h)
    # grab optional subcommand before options parsing
    HELP_SUBCMD="${1:-}"
    shift || true
    ;;
  *)
    # All other commands require a session name as first argument
    SESSION_NAME="${1:-}"
    if [ -z "$SESSION_NAME" ]; then
      echo "ERROR: Session name is required."
      echo ""
      echo "  Usage: claude-sandbox $COMMAND <session-name> [options]"
      echo ""
      echo "  Example: claude-sandbox $COMMAND my-feature"
      exit 1
    fi
    # Validate session name: must start with letter/digit, then [a-zA-Z0-9._-]
    if [[ ! "$SESSION_NAME" =~ ^[a-zA-Z0-9][a-zA-Z0-9._-]*$ ]]; then
      echo "ERROR: Invalid session name '$SESSION_NAME'."
      echo ""
      echo "  Names must start with a letter or digit and contain only"
      echo "  letters, digits, hyphens, underscores, and dots."
      echo ""
      echo "  Usage: claude-sandbox $COMMAND <session-name> [options]"
      echo "  Example: claude-sandbox $COMMAND my-feature"
      exit 1
    fi
    shift
    ;;
esac

# ── Derive container/volume names from session name ─────────────────────────
if [ -n "${SESSION_NAME:-}" ]; then
  CONTAINER_NAME="claude-sandbox-${SESSION_NAME}"
  VOLUME_NAME="claude-sandbox-workspace-${SESSION_NAME}"
  COMPOSE="$COMPOSE --project-name claude-sandbox-${SESSION_NAME}"
  export CONTAINER_NAME SESSION_NAME VOLUME_NAME
fi

# ── Parse remaining options ─────────────────────────────────────────────────
PR_REF=""
SKIP_PERMISSIONS="false"
PROMPT_ARG=""
POST_REVIEW="false"
KEEP_SESSION="false"
AUTO_REMOVE="false"
REPO_DIRS=()
COPY_ENTRIES=()
RESOLVED_COPIES=()
DEFAULT_WORKDIR=""
INSTALL_PREFIX=""

while [ $# -gt 0 ]; do
  case "$1" in
    --pr=*)          PR_REF="${1#--pr=}" ;;
    --prompt=*)      PROMPT_ARG="${1#--prompt=}" ;;
    --post)          POST_REVIEW="true" ;;
    --keep)          KEEP_SESSION="true" ;;
    --rm)            AUTO_REMOVE="true" ;;
    --dangerously-skip-permissions) SKIP_PERMISSIONS="true" ;;
    --help|-h)       usage; exit 0 ;;
    --repo=*)        REPO_DIRS+=("${1#--repo=}") ;;
    --repo)          shift; [ -n "${1:-}" ] || { echo "ERROR: --repo requires a value"; exit 1; }; REPO_DIRS+=("$1") ;;
    --copy=*)        COPY_ENTRIES+=("${1#--copy=}") ;;
    --copy)          shift; [ -n "${1:-}" ] || { echo "ERROR: --copy requires a value"; exit 1; }; COPY_ENTRIES+=("$1") ;;
    --prefix=*)      INSTALL_PREFIX="${1#--prefix=}" ;; # used by install command
    *)               echo "Unknown option: $1"; usage; exit 1 ;;
  esac
  shift
done

# ── Resolve repo directories ───────────────────────────────────────────────
# Only for commands that create sessions (launch, start, run)
if [[ "$COMMAND" =~ ^(launch|start|run)$ ]]; then
  # Default to CWD if no --repo flags
  if [ ${#REPO_DIRS[@]} -eq 0 ]; then
    REPO_DIRS=("$ORIGINAL_CWD")
  fi

  # Resolve to absolute paths and validate
  RESOLVED_DIRS=()
  BASENAMES=()
  for entry in "${REPO_DIRS[@]}"; do
    # Split on first colon to get path and optional name
    dir="${entry%%:*}"
    custom_name="${entry#*:}"
    # If no colon was found, custom_name equals entry (no override)
    if [ "$custom_name" = "$entry" ]; then
      custom_name=""
    fi

    # Expand leading ~ to $HOME (shell doesn't expand tilde inside --repo=~/...)
    [[ "$dir" == "~/"* ]] && dir="$HOME/${dir#\~/}"
    [[ "$dir" == "~" ]] && dir="$HOME"
    abs_dir="$(cd "$dir" 2>/dev/null && pwd)" || {
      echo "ERROR: Directory does not exist: $dir"
      exit 1
    }
    if [ -z "$(ls -A "$abs_dir" 2>/dev/null)" ]; then
      echo "ERROR: Directory is empty: $abs_dir"
      exit 1
    fi

    # Use custom name if provided, otherwise basename
    if [ -n "$custom_name" ]; then
      bname="$custom_name"
    else
      bname=$(basename "$abs_dir")
    fi

    # Check for basename collisions
    for existing in "${BASENAMES[@]+"${BASENAMES[@]}"}"; do
      if [ "$existing" = "$bname" ]; then
        echo "ERROR: Workspace name collision — two repos named '$bname'."
        echo "  Use --repo=<path>:<name> to give one a different name."
        exit 1
      fi
    done
    BASENAMES+=("$bname")
    RESOLVED_DIRS+=("${abs_dir}:${bname}")
  done
  REPO_DIRS=("${RESOLVED_DIRS[@]}")

  # Compute DEFAULT_WORKDIR (first repo's name)
  first_bname="${REPO_DIRS[0]##*:}"
  DEFAULT_WORKDIR="/workspace/${first_bname}"
  export DEFAULT_WORKDIR
fi

# ── Parse and validate --copy entries + sandbox.yaml custom_files ────────────
# Populates RESOLVED_COPIES array with entries: "host_path:container_dest:mode"
parse_copy_entries() {
  RESOLVED_COPIES=()

  # Step 1: Read custom_files from sandbox.yaml (if exists)
  local CONFIG_FILE=""
  if [ -f "$SCRIPT_DIR/config/sandbox.yaml" ]; then
    CONFIG_FILE="$SCRIPT_DIR/config/sandbox.yaml"
  elif [ -f "$SCRIPT_DIR/config/workspace.yaml" ]; then
    CONFIG_FILE="$SCRIPT_DIR/config/workspace.yaml"
  fi

  if [ -n "$CONFIG_FILE" ] && command -v yq &>/dev/null; then
    local FILE_COUNT
    FILE_COUNT=$(yq '.custom_files | length' "$CONFIG_FILE" 2>/dev/null || echo 0)

    if [ "$FILE_COUNT" -gt 0 ]; then
    for i in $(seq 0 $((FILE_COUNT - 1))); do
      local src dest mode
      src=$(yq ".custom_files[$i].source // \"\"" "$CONFIG_FILE")
      dest=$(yq ".custom_files[$i].dest // \"\"" "$CONFIG_FILE")
      mode=$(yq ".custom_files[$i].mode // \"\"" "$CONFIG_FILE")

      if [ -z "$src" ]; then
        echo "ERROR: custom_files[$i] in sandbox.yaml is missing 'source'"
        return 1
      fi

      resolve_copy_entry "$src" "$dest" "$mode" "sandbox.yaml custom_files[$i]" || return 1
    done
    fi
  fi

  # Step 2: Parse CLI --copy entries (these override sandbox.yaml on collision)
  for raw in "${COPY_ENTRIES[@]+"${COPY_ENTRIES[@]}"}"; do
    # Parse colon-delimited: source[:dest][:mode]
    local src dest mode
    IFS=':' read -r src dest mode <<< "$raw"

    resolve_copy_entry "$src" "$dest" "$mode" "--copy=$raw" || return 1
  done
}

# Resolve a single copy entry: expand paths, validate, append to RESOLVED_COPIES
# Usage: resolve_copy_entry <source> <dest> <mode> <label>
resolve_copy_entry() {
  local src="$1" dest="$2" mode="$3" label="$4"

  # Expand ~ in source
  [[ "$src" == "~/"* ]] && src="$HOME/${src#\~/}"
  [[ "$src" == "~" ]] && src="$HOME"

  # Resolve to absolute path
  if [[ "$src" != /* ]]; then
    src="$ORIGINAL_CWD/$src"
  fi
  # Normalize path (resolve ./ and ../)
  src="$(cd "$(dirname "$src")" 2>/dev/null && echo "$(pwd)/$(basename "$src")")" || {
    echo "ERROR: Source path does not exist ($label): $src"
    return 1
  }

  # Validate source exists
  if [ ! -e "$src" ]; then
    echo "ERROR: Source path does not exist ($label): $src"
    return 1
  fi

  # Default mode
  if [ -z "$mode" ]; then
    mode="ro"
  fi

  # Validate mode
  if [ "$mode" != "ro" ] && [ "$mode" != "rw" ]; then
    echo "ERROR: Invalid mode '$mode' ($label). Must be 'ro' or 'rw'."
    return 1
  fi

  # Resolve destination
  if [ -z "$dest" ]; then
    # Default: same path, with $HOME → /home/claude/
    dest="${src/#$HOME//home/claude}"
  else
    # Expand ~ in dest
    [[ "$dest" == "~/"* ]] && dest="/home/claude/${dest#\~/}"
    [[ "$dest" == "~" ]] && dest="/home/claude"
  fi

  RESOLVED_COPIES+=("${src}:${dest}:${mode}")
}

# ── Helper: check if container exists / is running ──────────────────────────
container_exists() {
  docker container inspect "$CONTAINER_NAME" &>/dev/null
}

container_running() {
  [ "$(docker container inspect -f '{{.State.Running}}' "$CONTAINER_NAME" 2>/dev/null)" = "true" ]
}

print_session_exit_message() {
  local session_name="$1"
  local mode="$2"  # "launch", "launch-rm", "attach", "run", "run-keep"

  echo ""
  echo "─────────────────────────────────────────────"
  case "$mode" in
    launch-rm|run)
      echo ":: Session '$session_name' has been removed."
      ;;
    launch|attach)
      echo ":: Session '$session_name' is still running."
      echo ""
      echo "  Re-attach:  claude-sandbox attach $session_name"
      echo "  Stop:       claude-sandbox stop $session_name"
      echo "  Delete:     claude-sandbox delete $session_name"
      ;;
    run-keep)
      echo ":: Session '$session_name' has been preserved (--keep)."
      echo ""
      echo "  Re-attach:  claude-sandbox start $session_name && claude-sandbox attach $session_name"
      echo "  Delete:     claude-sandbox delete $session_name"
      ;;
  esac
  echo "─────────────────────────────────────────────"
}

# ── Ensure socat SSH agent relay is running (macOS only) ─────────────────────
# Sets AGENT_SOCK to the relay path on macOS, or SSH_AUTH_SOCK on Linux.
# On Linux this is a no-op (AGENT_SOCK = SSH_AUTH_SOCK).
ensure_ssh_relay() {
  AGENT_SOCK="${SSH_AUTH_SOCK:-}"

  # Only needed on macOS — launchd rotates SSH_AUTH_SOCK paths after sleep/wake
  [[ "$OSTYPE" == darwin* ]] || return 0

  local RELAY_SOCK="$HOME/.claude/ssh-agent.sock"
  local RELAY_PID_FILE="$HOME/.claude/ssh-agent-relay.pid"

  if ! command -v socat &>/dev/null; then
    echo "ERROR: 'socat' is required for SSH agent forwarding on macOS."
    echo ""
    echo "  Install with: brew install socat"
    echo "  Then retry."
    return 1
  fi

  if [ -z "${SSH_AUTH_SOCK:-}" ]; then
    echo "ERROR: git_config.ssh_agent is true but SSH_AUTH_SOCK is not set."
    echo ""
    echo "  Start your SSH agent:"
    echo "    eval \"\$(ssh-agent -s)\""
    echo "    ssh-add"
    return 1
  fi

  if [ ! -S "$SSH_AUTH_SOCK" ]; then
    echo "ERROR: git_config.ssh_agent is true but SSH_AUTH_SOCK ($SSH_AUTH_SOCK) is not a valid socket."
    echo ""
    echo "  Verify your SSH agent is running: ssh-add -l"
    return 1
  fi

  # Kill any existing relay (may point to stale socket after sleep/wake)
  if [ -f "$RELAY_PID_FILE" ]; then
    kill "$(cat "$RELAY_PID_FILE")" 2>/dev/null || true
  fi
  rm -f "$RELAY_SOCK" "$RELAY_PID_FILE"

  mkdir -p "$HOME/.claude"
  socat UNIX-LISTEN:"$RELAY_SOCK",fork UNIX-CONNECT:"$SSH_AUTH_SOCK" &
  echo $! > "$RELAY_PID_FILE"

  # Wait for relay socket to appear
  for i in $(seq 1 10); do
    [ -S "$RELAY_SOCK" ] && break
    sleep 0.1
  done

  if [ ! -S "$RELAY_SOCK" ]; then
    echo "ERROR: SSH agent relay failed to start."
    echo "  Check that socat is working: socat -V"
    return 1
  fi

  AGENT_SOCK="$RELAY_SOCK"
  echo "  SSH agent relay started (PID $(cat "$RELAY_PID_FILE"))"
}

# ── Start SSH relay if ssh_agent is enabled in config ────────────────────────
# Call this before docker start on the restart path (where generate_compose_override is skipped).
maybe_start_ssh_relay() {
  local CONFIG_FILE=""
  if [ -f "$SCRIPT_DIR/config/sandbox.yaml" ]; then
    CONFIG_FILE="$SCRIPT_DIR/config/sandbox.yaml"
  elif [ -f "$SCRIPT_DIR/config/workspace.yaml" ]; then
    CONFIG_FILE="$SCRIPT_DIR/config/workspace.yaml"
  fi
  [ -z "$CONFIG_FILE" ] && return 0

  local SSH_AGENT
  SSH_AGENT=$(yq '.git_config.ssh_agent // false' "$CONFIG_FILE" 2>/dev/null)
  if [ "$SSH_AGENT" = "true" ]; then
    ensure_ssh_relay || return 1
  fi
}

# ── Generate docker-compose.override.yaml from sandbox.yaml git_config ───────
generate_compose_override() {
  local CONFIG_FILE=""
  if [ -f "$SCRIPT_DIR/config/sandbox.yaml" ]; then
    CONFIG_FILE="$SCRIPT_DIR/config/sandbox.yaml"
  elif [ -f "$SCRIPT_DIR/config/workspace.yaml" ]; then
    echo "NOTE: workspace.yaml is deprecated. Rename to sandbox.yaml and remove the repos[] section."
    CONFIG_FILE="$SCRIPT_DIR/config/workspace.yaml"
  fi
  local OVERRIDE_FILE="$SCRIPT_DIR/docker-compose.override.yaml"

  # If no config file, skip SSH/gitconfig validation but continue for source dirs
  local MOUNT_SSH="false"
  local MOUNT_GITCONFIG="false"
  local SSH_AGENT="false"
  local CONTAINER_BUILDS="true"

  if [ -n "$CONFIG_FILE" ]; then
    # yq is required to parse sandbox.yaml
    if ! command -v yq &>/dev/null; then
      echo "ERROR: 'yq' is required but not found on this machine."
      echo "  Install: brew install yq (macOS) or see https://github.com/mikefarah/yq"
      return 1
    fi

    MOUNT_SSH=$(yq '.git_config.mount_ssh // false' "$CONFIG_FILE" 2>/dev/null)
    MOUNT_GITCONFIG=$(yq '.git_config.mount_gitconfig // false' "$CONFIG_FILE" 2>/dev/null)
    SSH_AGENT=$(yq '.git_config.ssh_agent // false' "$CONFIG_FILE" 2>/dev/null)
    CONTAINER_BUILDS=$(yq '.container_builds // true' "$CONFIG_FILE" 2>/dev/null)

  # Validate: any server with auth_method: ssh requires mount_ssh: true
  local SERVER_COUNT
  SERVER_COUNT=$(yq '.github_servers | length' "$CONFIG_FILE" 2>/dev/null || echo 0)
  for i in $(seq 0 $((SERVER_COUNT - 1))); do
    local AUTH_METHOD HOST
    AUTH_METHOD=$(yq ".github_servers[$i].auth_method // \"https\"" "$CONFIG_FILE")
    HOST=$(yq ".github_servers[$i].host" "$CONFIG_FILE")

    if [ "$AUTH_METHOD" = "ssh" ] && [ "$MOUNT_SSH" != "true" ] && [ "$SSH_AGENT" != "true" ]; then
      echo "ERROR: Server '$HOST' uses auth_method: ssh but neither git_config.mount_ssh nor git_config.ssh_agent is enabled."
      echo ""
      echo "  Add one of these to config/sandbox.yaml:"
      echo "    git_config:"
      echo "      ssh_agent: true      # recommended: forward host SSH agent"
      echo "      mount_ssh: true      # alternative: mount key files"
      return 1
    fi

    # Validate ssh_key: requires mount_ssh (key files need the mount even with agent)
    if [ "$AUTH_METHOD" = "ssh" ]; then
      local SSH_KEY
      SSH_KEY=$(yq ".github_servers[$i].ssh_key // \"\"" "$CONFIG_FILE")
      if [ -n "$SSH_KEY" ]; then
        if [ "$MOUNT_SSH" != "true" ]; then
          echo "ERROR: Server '$HOST' specifies ssh_key: $SSH_KEY but git_config.mount_ssh is not true."
          echo "  ssh_key requires mount_ssh: true to make the key file available in the container."
          return 1
        fi
        if [ ! -f "$HOME/.ssh/$SSH_KEY" ]; then
          echo "ERROR: SSH key '$HOME/.ssh/$SSH_KEY' not found (server '$HOST')."
          return 1
        fi
      fi
    fi
  done

  # Validate host paths exist
  if [ "$MOUNT_SSH" = "true" ] && [ ! -d "$HOME/.ssh" ]; then
    echo "ERROR: git_config.mount_ssh is true but $HOME/.ssh/ does not exist."
    return 1
  fi

  if [ "$MOUNT_GITCONFIG" = "true" ] && [ ! -f "$HOME/.gitconfig" ]; then
    echo "WARN: git_config.mount_gitconfig is true but $HOME/.gitconfig does not exist. Skipping gitconfig mount."
    MOUNT_GITCONFIG="false"
  fi

  # Start SSH agent relay (macOS) or set AGENT_SOCK directly (Linux)
  if [ "$SSH_AGENT" = "true" ]; then
    ensure_ssh_relay || return 1
  fi

  fi  # end if [ -n "$CONFIG_FILE" ]

  # Determine if override file is needed
  local NEED_OVERRIDE="false"
  if [ "$MOUNT_SSH" = "true" ] || [ "$MOUNT_GITCONFIG" = "true" ] || [ "$SSH_AGENT" = "true" ]; then
    NEED_OVERRIDE="true"
  fi
  if [ -n "${DEFAULT_WORKDIR:-}" ]; then
    NEED_OVERRIDE="true"
  fi
  if [ "$CONTAINER_BUILDS" = "true" ]; then
    NEED_OVERRIDE="true"
  fi

  if [ "$NEED_OVERRIDE" = "true" ]; then
    local NEED_ENV="false"
    {
      echo "# Generated by claude-sandbox — do not edit"
      echo "services:"
      echo "  claude-sandbox:"
      if [ "$CONTAINER_BUILDS" = "true" ]; then
        echo "    security_opt:"
        echo "      - seccomp=unconfined"
        echo "    cap_add:"
        echo "      - SYS_ADMIN"
        echo "      - SETUID"
        echo "      - SETGID"
        echo "    devices:"
        echo "      - /dev/fuse"
      fi
      if [ "$MOUNT_SSH" = "true" ] || [ "$MOUNT_GITCONFIG" = "true" ] || [ "$SSH_AGENT" = "true" ]; then
        echo "    volumes:"
        if [ "$MOUNT_SSH" = "true" ]; then
          echo "      - ${HOME}/.ssh:/home/claude/.ssh:ro"
        fi
        if [ "$MOUNT_GITCONFIG" = "true" ]; then
          echo "      - ${HOME}/.gitconfig:/home/claude/.gitconfig.host:ro"
        fi
        if [ "$SSH_AGENT" = "true" ]; then
          echo "      - \"${AGENT_SOCK}:/run/ssh-agent.sock\""
          NEED_ENV="true"
        fi
      fi
      if [ "$NEED_ENV" = "true" ] || [ -n "${DEFAULT_WORKDIR:-}" ]; then
        echo "    environment:"
        if [ "$NEED_ENV" = "true" ]; then
          echo "      - SSH_AUTH_SOCK=/run/ssh-agent.sock"
        fi
        if [ -n "${DEFAULT_WORKDIR:-}" ]; then
          echo "      - DEFAULT_WORKDIR=${DEFAULT_WORKDIR}"
        fi
      fi
    } > "$OVERRIDE_FILE"
  else
    # No mounts needed — remove stale override
    rm -f "$OVERRIDE_FILE"
  fi
}

# ── Copy custom files/dirs into running container via docker cp ───────────
copy_custom_files() {
  if [ ${#RESOLVED_COPIES[@]} -eq 0 ]; then
    return 0
  fi

  echo ":: Copying custom files into container..."

  for entry in "${RESOLVED_COPIES[@]}"; do
    local src dest mode
    IFS=':' read -r src dest mode <<< "$entry"

    # Create parent directory in container
    local dest_parent
    if [ -d "$src" ]; then
      dest_parent="$dest"
    else
      dest_parent="$(dirname "$dest")"
    fi
    docker exec "$CONTAINER_NAME" mkdir -p "$dest_parent" || {
      echo "ERROR: Failed to create directory $dest_parent in container"
      return 1
    }

    # Copy file or directory
    if [ -d "$src" ]; then
      # Directory copy: create dest dir, copy contents
      docker exec "$CONTAINER_NAME" mkdir -p "$dest"
      docker cp "$src/." "$CONTAINER_NAME:$dest" || {
        echo "ERROR: Failed to copy directory $src to $dest"
        return 1
      }
      echo "  $src/ -> $dest/ ($mode)"
    else
      docker cp "$src" "$CONTAINER_NAME:$dest" || {
        echo "ERROR: Failed to copy file $src to $dest"
        return 1
      }
      echo "  $src -> $dest ($mode)"
    fi
  done

  # Fix ownership for all copied files (covers both /workspace/ and /home/claude/ targets)
  docker exec -u root "$CONTAINER_NAME" chown -R claude:claude /home/claude/ || true
  if docker exec "$CONTAINER_NAME" test -d /workspace/ 2>/dev/null; then
    docker exec -u root "$CONTAINER_NAME" chown -R claude:claude /workspace/ || true
  fi

  # Apply read-only permissions for ro entries
  for entry in "${RESOLVED_COPIES[@]}"; do
    local src dest mode
    IFS=':' read -r src dest mode <<< "$entry"
    if [ "$mode" = "ro" ]; then
      docker exec -u root "$CONTAINER_NAME" chmod -R a-w "$dest"
    fi
  done

  echo " ✔ Custom files copied"
}

# ── Copy repos + custom files into running container via docker cp ─────────
copy_all_to_container() {
  local HAS_REPOS=false
  local HAS_COPIES=false
  [ ${#REPO_DIRS[@]} -gt 0 ] && HAS_REPOS=true
  [ ${#RESOLVED_COPIES[@]} -gt 0 ] && HAS_COPIES=true

  if [ "$HAS_REPOS" = "false" ] && [ "$HAS_COPIES" = "false" ]; then
    # Nothing to copy — signal copy-done immediately so entrypoint proceeds
    docker exec "$CONTAINER_NAME" touch /workspace/.claude-session/copy-done 2>/dev/null || true
    return 0
  fi

  # Wait for entrypoint to signal it's ready for copy
  local COPY_READY_TIMEOUT=60
  for i in $(seq 1 "$COPY_READY_TIMEOUT"); do
    if docker exec "$CONTAINER_NAME" test -f /workspace/.claude-session/copy-ready 2>/dev/null; then
      break
    fi
    if ! container_running; then
      echo "ERROR: Container stopped before copy could begin."
      return 1
    fi
    sleep 1
  done

  if ! docker exec "$CONTAINER_NAME" test -f /workspace/.claude-session/copy-ready 2>/dev/null; then
    echo "ERROR: Container did not signal copy-ready within ${COPY_READY_TIMEOUT}s."
    return 1
  fi

  # Phase 1: Copy repo directories
  if [ "$HAS_REPOS" = "true" ]; then
    echo ":: Copying repo directories into container..."
    for entry in "${REPO_DIRS[@]}"; do
      local host_path="${entry%%:*}"
      local bname="${entry##*:}"
      # Skip if directory already exists in workspace (restart case)
      if docker exec "$CONTAINER_NAME" test -d "/workspace/$bname" 2>/dev/null; then
        echo "  /workspace/$bname already exists, skipping copy"
        continue
      fi
      echo "  Copying $bname to container:/workspace/$bname ..."
      docker cp "$host_path/." "$CONTAINER_NAME:/workspace/$bname" || {
        echo "ERROR: Failed to copy $bname"
        return 1
      }
    done

    # Fix ownership for workspace (docker cp creates files as root)
    docker exec -u root "$CONTAINER_NAME" chown -R claude:claude /workspace/
    echo " ✔ Repo directories copied"
  fi

  # Phase 2: Copy custom files (after repos, so --copy can target /workspace/<repo>/)
  copy_custom_files || return 1

  # Signal completion to entrypoint
  docker exec "$CONTAINER_NAME" touch /workspace/.claude-session/copy-done
}

# ── QEMU binfmt detection and setup ──────────────────────────────────────────
# Check if QEMU binfmt handlers are registered (for multi-arch builds)
qemu_is_registered() {
  # Fast local check (Linux host)
  if [ -d /proc/sys/fs/binfmt_misc ] && ls /proc/sys/fs/binfmt_misc/qemu-* &>/dev/null; then
    return 0
  fi
  # Fallback: check inside Docker VM (macOS Docker Desktop)
  if [ ! -d /proc/sys/fs/binfmt_misc ]; then
    if docker run --rm --privileged alpine ls /proc/sys/fs/binfmt_misc/qemu-* &>/dev/null 2>&1; then
      return 0
    fi
  fi
  return 1
}

# Register QEMU binfmt handlers
register_qemu() {
  echo ":: Registering QEMU binfmt handlers..."
  if docker run --privileged --rm tonistiigi/binfmt --install all 2>&1; then
    echo " ✔ QEMU multi-arch support enabled"
    return 0
  else
    echo "  Failed to register QEMU automatically."
    echo "  Run this manually on your host:"
    echo "    docker run --privileged --rm tonistiigi/binfmt --install all"
    return 1
  fi
}

# Read container_builds setting from sandbox.yaml (returns "true" or "false")
read_container_builds() {
  local CONFIG_FILE=""
  if [ -f "$SCRIPT_DIR/config/sandbox.yaml" ]; then
    CONFIG_FILE="$SCRIPT_DIR/config/sandbox.yaml"
  elif [ -f "$SCRIPT_DIR/config/workspace.yaml" ]; then
    CONFIG_FILE="$SCRIPT_DIR/config/workspace.yaml"
  fi

  if [ -n "$CONFIG_FILE" ] && command -v yq &>/dev/null; then
    yq '.container_builds // true' "$CONFIG_FILE" 2>/dev/null
  else
    echo "true"
  fi
}

# Read qemu_prompt setting from sandbox.yaml (returns "true" or "false")
read_qemu_prompt() {
  local CONFIG_FILE=""
  if [ -f "$SCRIPT_DIR/config/sandbox.yaml" ]; then
    CONFIG_FILE="$SCRIPT_DIR/config/sandbox.yaml"
  elif [ -f "$SCRIPT_DIR/config/workspace.yaml" ]; then
    CONFIG_FILE="$SCRIPT_DIR/config/workspace.yaml"
  fi

  if [ -n "$CONFIG_FILE" ] && command -v yq &>/dev/null; then
    yq '.qemu_prompt // true' "$CONFIG_FILE" 2>/dev/null
  else
    echo "true"
  fi
}

# Write qemu_prompt: false to sandbox.yaml
suppress_qemu_prompt() {
  local CONFIG_FILE=""
  if [ -f "$SCRIPT_DIR/config/sandbox.yaml" ]; then
    CONFIG_FILE="$SCRIPT_DIR/config/sandbox.yaml"
  elif [ -f "$SCRIPT_DIR/config/workspace.yaml" ]; then
    CONFIG_FILE="$SCRIPT_DIR/config/workspace.yaml"
  fi

  if [ -n "$CONFIG_FILE" ] && command -v yq &>/dev/null; then
    yq -i '.qemu_prompt = false' "$CONFIG_FILE"
    echo "  Prompt suppressed. Run 'claude-sandbox enable-qemu' to re-enable."
  fi
}

# Clear qemu_prompt suppression in sandbox.yaml
clear_qemu_prompt_suppression() {
  local CONFIG_FILE=""
  if [ -f "$SCRIPT_DIR/config/sandbox.yaml" ]; then
    CONFIG_FILE="$SCRIPT_DIR/config/sandbox.yaml"
  elif [ -f "$SCRIPT_DIR/config/workspace.yaml" ]; then
    CONFIG_FILE="$SCRIPT_DIR/config/workspace.yaml"
  fi

  if [ -n "$CONFIG_FILE" ] && command -v yq &>/dev/null; then
    yq -i 'del(.qemu_prompt)' "$CONFIG_FILE" 2>/dev/null || true
  fi
}

# Interactive QEMU prompt for start/launch
maybe_prompt_qemu() {
  local BUILDS
  BUILDS=$(read_container_builds)
  [ "$BUILDS" = "true" ] || return 0

  # Already registered — nothing to do
  if qemu_is_registered; then
    return 0
  fi

  # User suppressed the prompt
  local PROMPT_SETTING
  PROMPT_SETTING=$(read_qemu_prompt)
  [ "$PROMPT_SETTING" = "true" ] || return 0

  echo ""
  echo ":: Multi-architecture image builds"
  echo ""
  echo "  QEMU is not configured on this host. Without it, you can only build"
  echo "  images for your native architecture ($(uname -m))."
  echo ""
  echo "  To enable cross-platform builds (e.g., linux/amd64 on arm64), we need"
  echo "  to register QEMU binfmt handlers in the host kernel. This runs:"
  echo ""
  echo "    docker run --privileged --rm tonistiigi/binfmt --install all"
  echo ""
  echo "  This is a one-time host-level change (not per-session). It affects all"
  echo "  Docker containers on this host, not just claude-sandbox."
  echo ""
  echo "  If you don't need to build images at all, you can disable Buildah"
  echo "  entirely by setting 'container_builds: false' in sandbox.yaml."
  echo ""
  echo "  [e] Enable QEMU multi-arch support now"
  echo "  [s] Skip for now (ask again next time)"
  echo "  [d] Don't ask again"
  echo ""
  read -rp "Choice [e/s/d]: " choice
  case "$choice" in
    e|E)
      register_qemu || true
      ;;
    d|D)
      suppress_qemu_prompt
      ;;
    *)
      echo "  Skipping QEMU setup."
      ;;
  esac
  echo ""
}

# Non-interactive QEMU warning for one-shot run mode
warn_qemu_if_missing() {
  local BUILDS
  BUILDS=$(read_container_builds)
  [ "$BUILDS" = "true" ] || return 0

  if ! qemu_is_registered; then
    echo ""
    echo "WARNING: QEMU multi-arch support is not configured. Cross-platform builds will fail."
    echo "  Run 'claude-sandbox enable-qemu' to fix this."
    echo ""
  fi
}

# ── Commands ─────────────────────────────────────────────────────────────────

case "$COMMAND" in
  build)
    $COMPOSE build
    ;;

  install)
    PREFIX="${INSTALL_PREFIX:-/usr/local/bin}"
    SYMLINK_TARGET="$PREFIX/claude-sandbox"
    SCRIPT_PATH="$SCRIPT_DIR/claude-sandbox"

    if [ -L "$SYMLINK_TARGET" ]; then
      echo "Symlink already exists at $SYMLINK_TARGET → $(readlink "$SYMLINK_TARGET")"
      echo "Updating to point to $SCRIPT_PATH"
      ln -sf "$SCRIPT_PATH" "$SYMLINK_TARGET"
    elif [ -e "$SYMLINK_TARGET" ]; then
      echo "ERROR: $SYMLINK_TARGET already exists and is not a symlink."
      echo "  Remove it manually if you want to proceed."
      exit 1
    else
      ln -s "$SCRIPT_PATH" "$SYMLINK_TARGET" 2>/dev/null || {
        echo "Permission denied. Try:"
        echo "  sudo claude-sandbox install"
        echo "  claude-sandbox install --prefix=\$HOME/.local/bin"
        exit 1
      }
    fi
    echo "Installed: $SYMLINK_TARGET → $SCRIPT_PATH"
    echo ""
    echo "You can now run 'claude-sandbox' from any directory."
    ;;

  launch)
    CLAUDE_ARGS=""
    if [ "$SKIP_PERMISSIONS" = "true" ]; then
      CLAUDE_ARGS="--dangerously-skip-permissions"
    fi

    # Set up cleanup trap if --rm (covers all exit paths including Ctrl+C)
    if [ "$AUTO_REMOVE" = "true" ]; then
      cleanup_session() {
        echo ""
        echo ":: Cleaning up session '$SESSION_NAME'..."
        docker stop "$CONTAINER_NAME" >/dev/null 2>&1 || true
        docker rm "$CONTAINER_NAME" >/dev/null 2>&1 || true
        docker volume rm "$VOLUME_NAME" >/dev/null 2>&1 || true
        echo ":: Session cleaned up."
      }
      trap cleanup_session EXIT
    fi

    # If already running, prompt the user
    if container_running; then
      echo "Session '$SESSION_NAME' is already running."
      echo ""
      echo "  [r] Re-attach to existing session"
      echo "  [d] Delete and create a new session"
      echo "  [q] Quit"
      echo ""
      read -rp "Choice [r/d/q]: " choice
      case "$choice" in
        r|R)
          REATTACH_WORKDIR=$(docker exec "$CONTAINER_NAME" printenv DEFAULT_WORKDIR 2>/dev/null || echo "/workspace")
          DOCKER_CLI_HINTS=false docker exec -it -w "$REATTACH_WORKDIR" "$CONTAINER_NAME" claude $CLAUDE_ARGS || true
          if [ "$AUTO_REMOVE" = "true" ]; then
            print_session_exit_message "$SESSION_NAME" "launch-rm"
          else
            print_session_exit_message "$SESSION_NAME" "launch"
          fi
          exit 0
          ;;
        d|D)
          echo ":: Deleting session '$SESSION_NAME'..."
          # Temporarily disable trap for the intentional delete
          trap - EXIT
          docker stop "$CONTAINER_NAME" >/dev/null
          docker rm "$CONTAINER_NAME" >/dev/null
          if docker volume inspect "$VOLUME_NAME" &>/dev/null; then
            docker volume rm "$VOLUME_NAME" >/dev/null
          fi
          # Re-enable trap for the new session
          if [ "$AUTO_REMOVE" = "true" ]; then
            trap cleanup_session EXIT
          fi
          # fall through to create new session
          ;;
        *)
          # Disable trap — user chose to quit, not to clean up
          trap - EXIT
          exit 0
          ;;
      esac
    fi

    # Restart stopped container or create new one
    if container_exists; then
      echo ":: Restarting stopped session '$SESSION_NAME'..."
      maybe_start_ssh_relay || exit 1
      docker start "$CONTAINER_NAME"
    else
      echo ":: Creating session '$SESSION_NAME'..."
      maybe_prompt_qemu
      parse_copy_entries || exit 1
      generate_compose_override || exit 1
      $COMPOSE up -d
    fi

    # Wait for container to be running
    for i in $(seq 1 30); do
      if container_running; then
        break
      fi
      sleep 1
    done
    if ! container_running; then
      echo "ERROR: Container did not start within 30 seconds."
      echo "  Check logs: docker logs $CONTAINER_NAME"
      exit 1
    fi
    echo " ✔ Container ready"

    # Copy source directories into container via docker cp
    copy_all_to_container || exit 1

    # Stream entrypoint output while waiting for setup to complete
    echo ""
    docker logs -f "$CONTAINER_NAME" 2>&1 &
    LOGS_PID=$!

    # Temporarily override trap to also clean up log streaming
    cleanup_logs() {
      kill "$LOGS_PID" 2>/dev/null || true
      wait "$LOGS_PID" 2>/dev/null || true
    }
    # Save the --rm cleanup for after logs are done
    PREV_TRAP="$AUTO_REMOVE"
    trap 'cleanup_logs; [ "$PREV_TRAP" = "true" ] && cleanup_session' EXIT

    # Poll for the readiness sentinel file
    READY_TIMEOUT=300
    for i in $(seq 1 "$READY_TIMEOUT"); do
      if docker exec "$CONTAINER_NAME" test -f /workspace/.claude-session/ready 2>/dev/null; then
        break
      fi
      if ! container_running; then
        cleanup_logs
        echo ""
        echo "ERROR: Container stopped unexpectedly during setup."
        echo "  Check logs: docker logs $CONTAINER_NAME"
        trap - EXIT
        exit 1
      fi
      sleep 1
    done

    # Stop log streaming, restore --rm-only trap
    cleanup_logs
    if [ "$AUTO_REMOVE" = "true" ]; then
      trap cleanup_session EXIT
    else
      trap - EXIT
    fi

    if ! docker exec "$CONTAINER_NAME" test -f /workspace/.claude-session/ready 2>/dev/null; then
      echo ""
      echo "ERROR: Setup did not complete within ${READY_TIMEOUT} seconds."
      echo "  Check logs: docker logs $CONTAINER_NAME"
      exit 1
    fi

    echo ""
    echo ":: Attaching to session '$SESSION_NAME'..."
    DOCKER_CLI_HINTS=false docker exec -it -w "${DEFAULT_WORKDIR:-/workspace}" "$CONTAINER_NAME" claude $CLAUDE_ARGS || true
    if [ "$AUTO_REMOVE" = "true" ]; then
      print_session_exit_message "$SESSION_NAME" "launch-rm"
    else
      print_session_exit_message "$SESSION_NAME" "launch"
    fi
    ;;

  start)
    # Check if session is already running
    if container_running; then
      echo "ERROR: Session '$SESSION_NAME' is already running."
      echo ""
      echo "  To attach:  claude-sandbox attach $SESSION_NAME"
      echo "  To stop:    claude-sandbox stop $SESSION_NAME"
      exit 1
    fi

    # Check if a stopped container exists — restart it
    if container_exists; then
      echo ":: Restarting stopped session '$SESSION_NAME'..."
      maybe_start_ssh_relay || exit 1
      docker start "$CONTAINER_NAME"
    else
      maybe_prompt_qemu
      parse_copy_entries || exit 1
      generate_compose_override || exit 1
      $COMPOSE up -d
    fi

    # Copy source directories into container via docker cp
    copy_all_to_container || exit 1

    echo ""
    echo "Session '$SESSION_NAME' started."
    echo "Attach with:  claude-sandbox attach $SESSION_NAME"
    ;;

  attach)
    if ! container_running; then
      if container_exists; then
        echo "ERROR: Session '$SESSION_NAME' is stopped."
        echo ""
        echo "  To restart: claude-sandbox start $SESSION_NAME"
        exit 1
      else
        echo "ERROR: Session '$SESSION_NAME' does not exist."
        echo ""
        echo "  To create:  claude-sandbox start $SESSION_NAME"
        echo "  To list:    claude-sandbox list"
        exit 1
      fi
    fi
    CLAUDE_ARGS=""
    if [ "$SKIP_PERMISSIONS" = "true" ]; then
      CLAUDE_ARGS="--dangerously-skip-permissions"
    fi
    # Retrieve DEFAULT_WORKDIR from running container (may have been set at creation)
    ATTACH_WORKDIR=$(docker exec "$CONTAINER_NAME" printenv DEFAULT_WORKDIR 2>/dev/null || echo "/workspace")
    DOCKER_CLI_HINTS=false docker exec -it -w "$ATTACH_WORKDIR" "$CONTAINER_NAME" claude $CLAUDE_ARGS || true
    print_session_exit_message "$SESSION_NAME" "attach"
    ;;

  run)
    # Parse --pr shorthand (supports org/repo#123 format)
    if [ -n "$PR_REF" ]; then
      if [[ "$PR_REF" == *"#"* ]]; then
        PR_REPO="${PR_REF%%#*}"
        PR_NUM="${PR_REF##*#}"
        PROMPT="Use the /review skill to review PR #$PR_NUM in repo $PR_REPO. Analyze all changes compared to the base branch. Output your review as markdown."
      else
        PR_NUM="$PR_REF"
        PROMPT="Use the /review skill to review PR #$PR_NUM. Analyze all changes compared to the base branch. Output your review as markdown."
      fi
    elif [ -n "$PROMPT_ARG" ]; then
      PROMPT="$PROMPT_ARG"
    else
      echo "ERROR: --prompt=<text> or --pr=<ref> is required for run."
      echo ""
      echo "  Examples:"
      echo "    claude-sandbox run $SESSION_NAME --prompt=\"Respond with: hello\""
      echo "    claude-sandbox run $SESSION_NAME --pr=123"
      exit 1
    fi

    # Clean up any existing container with the same name (from a prior --keep)
    if container_exists; then
      docker stop "$CONTAINER_NAME" >/dev/null 2>&1 || true
      docker rm "$CONTAINER_NAME" >/dev/null 2>&1 || true
      docker volume rm "$VOLUME_NAME" >/dev/null 2>&1 || true
    fi

    export ONE_SHOT_PROMPT="$PROMPT"

    # Non-interactive QEMU warning for one-shot mode
    warn_qemu_if_missing

    # Start container detached, copy source dirs, then wait for completion
    parse_copy_entries || exit 1
    generate_compose_override || exit 1
    $COMPOSE up -d

    # Copy source directories via docker cp
    copy_all_to_container || exit 1

    # Stream logs and wait for container to finish (one-shot exits after prompt)
    echo ""
    docker logs -f "$CONTAINER_NAME" 2>&1 &
    LOGS_PID=$!
    docker wait "$CONTAINER_NAME" >/dev/null 2>&1 || true
    kill "$LOGS_PID" 2>/dev/null || true
    wait "$LOGS_PID" 2>/dev/null || true

    # Extract output using docker cp (container is stopped after --abort-on-container-exit)
    OUTPUT_FILE=$(mktemp)
    docker cp "$CONTAINER_NAME:/workspace/.claude-session/output.md" "$OUTPUT_FILE" 2>/dev/null || true

    # Post review if --post and --pr
    if [ "$POST_REVIEW" = "true" ] && [ -n "$PR_REF" ]; then
      if [ -s "$OUTPUT_FILE" ]; then
        echo ":: Posting review to GitHub..."
        REVIEW_BODY=$(cat "$OUTPUT_FILE")
        gh pr review "${PR_NUM}" ${PR_REPO:+--repo "$PR_REPO"} --comment --body "$REVIEW_BODY"
        echo "  Review posted to PR #${PR_NUM}"
      else
        echo "ERROR: No output to post. Check session logs."
      fi
    fi
    rm -f "$OUTPUT_FILE"

    # Default: auto-remove. --keep to preserve.
    if [ "$KEEP_SESSION" != "true" ]; then
      docker rm "$CONTAINER_NAME" >/dev/null 2>&1 || true
      docker volume rm "$VOLUME_NAME" >/dev/null 2>&1 || true
      print_session_exit_message "$SESSION_NAME" "run"
    else
      print_session_exit_message "$SESSION_NAME" "run-keep"
    fi
    ;;

  status)
    if ! container_exists; then
      echo "ERROR: Session '$SESSION_NAME' does not exist."
      exit 1
    fi
    if container_running; then
      docker exec "$CONTAINER_NAME" /scripts/monitor.sh
    else
      echo "Session '$SESSION_NAME' is stopped."
      echo ""
      echo "  To restart: claude-sandbox start $SESSION_NAME"
      echo "  To delete:  claude-sandbox delete $SESSION_NAME"
    fi
    ;;

  logs)
    if ! container_running; then
      echo "ERROR: Session '$SESSION_NAME' is not running."
      exit 1
    fi
    docker exec "$CONTAINER_NAME" tail -f /workspace/.claude-session/output.log
    ;;

  stop)
    if ! container_exists; then
      echo "ERROR: Session '$SESSION_NAME' does not exist."
      exit 1
    fi
    docker stop "$CONTAINER_NAME" >/dev/null
    echo "Session '$SESSION_NAME' stopped."
    echo ""
    echo "  To restart: claude-sandbox start $SESSION_NAME"
    echo "  To delete:  claude-sandbox delete $SESSION_NAME"
    ;;

  delete)
    if ! container_exists; then
      echo "ERROR: Session '$SESSION_NAME' does not exist."
      echo ""
      echo "  To list sessions: claude-sandbox list"
      exit 1
    fi
    # Stop if running
    if container_running; then
      docker stop "$CONTAINER_NAME" >/dev/null
    fi
    # Remove container
    docker rm "$CONTAINER_NAME" >/dev/null
    # Remove volume
    if docker volume inspect "$VOLUME_NAME" &>/dev/null; then
      docker volume rm "$VOLUME_NAME" >/dev/null
    fi
    echo "Session '$SESSION_NAME' permanently deleted."
    ;;

  list)
    echo "Sessions:"
    echo ""
    COUNT=$(docker ps -a --filter "label=com.claude-sandbox.session=true" -q 2>/dev/null | wc -l | tr -d ' ')
    if [ "$COUNT" = "0" ]; then
      echo "  (no sessions)"
      echo ""
      echo "  To start one: claude-sandbox start <session-name>"
    else
      printf "  %-30s %s\n" "NAME" "STATUS"
      docker ps -a --filter "label=com.claude-sandbox.session=true" \
        --format "{{.Names}}\t{{.Status}}" 2>/dev/null | \
        while IFS=$'\t' read -r name status; do
          session="${name#claude-sandbox-}"
          printf "  %-30s %s\n" "$session" "$status"
        done
    fi
    ;;

  enable-qemu)
    echo ":: Enabling QEMU multi-arch support..."
    if qemu_is_registered; then
      echo " ✔ QEMU binfmt handlers are already registered."
    else
      register_qemu || exit 1
    fi
    clear_qemu_prompt_suppression
    ;;

  help|--help|-h)
    command_help "${HELP_SUBCMD:-}"
    ;;

  "")
    usage
    exit 1
    ;;

  *)
    echo "Unknown command: $COMMAND"
    usage
    exit 1
    ;;
esac
