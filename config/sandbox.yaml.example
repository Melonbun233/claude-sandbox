# ── Git Configuration (optional) ─────────────────────────────────────────────
# Control how the container accesses git. All options are opt-in.
# git_config:
#   ssh_agent: true           # forward host SSH agent socket (for passphrase-protected keys)
#   mount_ssh: true           # mount host ~/.ssh/ read-only (for unencrypted key files)
#   mount_gitconfig: true     # mount host ~/.gitconfig read-only into container

# ── GitHub Servers ────────────────────────────────────────────────────────────
# Each entry defines a hostname and how to authenticate.
#
# auth_method: https (default) — uses PAT via git-credential-store
# auth_method: ssh — uses SSH keys (requires git_config.ssh_agent or mount_ssh)
#
# SSL options (for GitHub Enterprise with corporate/self-signed certs):
#   ssl_verify: false     — skip TLS certificate verification
#   ca_cert: corp-ca.pem  — use a custom CA cert from ./certs/ directory
github_servers:
  - host: github.com
    auth_method: https         # ssh | https (default: https)
    token_env: GH_TOKEN        # required for auth_method: https
    # user_name: Jane Doe
    # user_email: jane@personal.com

  # SSH example for enterprise server:
  # When using auth_method: ssh, enable either ssh_agent: true (recommended)
  # or mount_ssh: true in git_config above.
  # - host: github.enterprise.corp.com
  #   auth_method: ssh
  #   ssh_key: id_ed25519_work   # optional: filename in ~/.ssh/ (requires mount_ssh)
  #   ssh_port: 22               # optional: non-standard SSH port
  #   token_env: GH_ENTERPRISE_TOKEN  # optional for SSH: enables gh CLI
  #   user_name: Jane Doe
  #   user_email: jane.doe@corp.com
  #   ssl_verify: false

# ── Custom Files (optional) ──────────────────────────────────────────────────
# Copy host files/directories into the container on every session start.
# Each entry needs a source path. dest defaults to the same path (~ → /home/claude/).
# mode defaults to 'ro' (read-only). Use 'rw' for writable copies.
#
# custom_files:
#   - source: ~/.aws
#   - source: ~/.kube/config
#   - source: ~/.npmrc
#     dest: /home/claude/.npmrc
#     mode: rw
#   - source: ./project-tools/lint.sh
#     dest: /workspace/api/tools/lint.sh
#     mode: rw

# ── Container Image Building (opt-out) ────────────────────────────────────────
# Buildah (rootless, daemonless) is enabled by default for building Docker images
# inside the sandbox. A `docker` shim maps build/push/tag/images/login/rmi to
# Buildah. Set to false to disable (restores default seccomp, removes /dev/fuse).
#
# container_builds: false

# ── Multi-arch Builds ─────────────────────────────────────────────────────────
# On first session start, you'll be prompted to enable QEMU binfmt handlers for
# cross-platform builds. If you chose "don't ask again", this is set to false.
# Run 'claude-sandbox enable-qemu' to re-enable the prompt and register QEMU.
#
# qemu_prompt: false
