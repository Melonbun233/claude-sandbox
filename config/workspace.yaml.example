# ── GitHub Servers ────────────────────────────────────────────────────────────
# List of GitHub servers to authenticate against.
# Each entry defines a hostname and the env var holding its PAT.
# The env vars must be set in .env or passed to docker-compose.
github_servers:
  - host: github.com
    token_env: GH_TOKEN

  # Add enterprise servers as needed:
  # - host: github.enterprise.sap.com
  #   token_env: GH_ENTERPRISE_TOKEN
  # - host: github.internal.corp.com
  #   token_env: GH_INTERNAL_TOKEN

# ── Repos to Clone ──────────────────────────────────────────────────────────
# Each repo is cloned to /workspace/<target> on container start.
# The URL host must match one of the github_servers above for auth.
repos: []
  # - url: https://github.com/org/repo1
  #   branch: main
  #   target: repo1
  #
  # - url: https://github.enterprise.sap.com/team/service
  #   branch: develop
  #   target: service
